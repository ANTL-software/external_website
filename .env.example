# EmailJS Configuration
# Pour utiliser EmailJS, créez un compte sur https://www.emailjs.com/
# Créez un service, deux templates (devis et candidature), et récupérez vos IDs

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_DEVIS=your_devis_template_id_here
VITE_EMAILJS_TEMPLATE_CANDIDATURE=your_candidature_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
